# CrossLens — environment variables
# Copy this file to .env and fill in your real values.

# PostgreSQL connection string (Neon, local Docker, Supabase Pooler, etc.)
# Example local: postgresql://postgres:postgres@localhost:5432/crosslens
DATABASE_URL=

# OpenRouter API key — used for contradiction analysis and reasoning.
# Get it at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cognee Cloud API key — used for document memory / knowledge graph.
# Get it at https://cognee.ai / https://cognee.ai/settings
COGNEE_API_KEY=

# Optional: override Cognee base URL (self-hosted users).
# Defaults to https://api.cognee.ai
# COGNEE_BASE_URL=http://localhost:8000
